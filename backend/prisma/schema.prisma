// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 사용자 정보
model User {
  id        			Int      @id @default(autoincrement())
		username					String?		@unique
  email     			String   @unique
  password  			String?		
  subdomain 			String   @unique // 여기에 user-id.oneresume.com의 id가 들어감.
		profileImage String? 	// 프로필 이미지 경로
		bio										String? 	// 한 줄 소개
		profileImageUrl String? // 프로필 사진, S3 URL 저장용
		githubUrl				String?  // 깃허브 링크 
		blogUrl						String?		// 블로그 링크
		age        					Int?     // 나이
		gender      				String?  // 성별
		phone      					String?  // 전화번호
		address      				String?  // 거주지 주소
		addressDetail				String?  // 상세 주소 (동, 호수 등)
		isProfileComplete Boolean @default(false) // 온보딩 완료 여부

// 이메일 인증 관련
		isVerified			Boolean		@default(false) // 인증 완료 여부
		verificationToken String? // 인증용 난수 토큰

// 소셜 로그인(OAuth) 관련
		provider		String			@default("LOCAL") // "LOCAL", "GITHUB", "GOOGLE" 등
		socialId		String?		@unique		// 소셜 서비스에서 제공하는 고유 ID

  resumes   Resume[]
  createdAt DateTime @default(now()) // 이력서 생성일
  updatedAt DateTime @updatedAt // 이력서 최종 수정일

// 비밀번호 찾기 관련
  resetPasswordToken String? // 임시 열쇠
		resetPasswordExpires DateTime? // 열쇠 만료 시간
}

// 이력서 기본 정보
model Resume {
  id        Int       @id @default(autoincrement())
  title     String    // 이력서 제목
  theme     String    @default("classic")
		education String?			// "학교|전공|학점|상태" 형태 또는 별도 모델
		skills				String?			// "기술 스택 부분"
		projects		Project[]
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now()) // 데이터 관리의 신뢰도: 이력서 하단에 "최종수정일: 2026..." 같은 문구를 자동으로 넣어주면, 인사담당자등 이 지원자는 정보를 계속 업데이트하는구나라고 신뢰를 줄 수 있음.
  updatedAt DateTime  @updatedAt // 나중에 사용자가 이력서를 여러 개 만들었을 때, "가장 최근에 수정된 이력서"를 상단에 보여주려면 필수, 디버깅에 효율적임.
}

// 프로젝트 경험
model Project {
  id          Int     @id @default(autoincrement())
  name        String  // 프로젝트명
  description String? @db.Text
		role								String? // 담당 역할
  techStack   String?  // 사용 기술 (JSON 문자열 등으로 저장)
		period						String?
  githubUrl   String?
  resumeId    Int
  resume      Resume  @relation(fields: [resumeId], references: [id])
}